---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const donateUrl = 'https://pages.razorpay.com/ISKCON-KVA-DONATION';

const navItems = [
  { label: 'Home', href: `${base}/` },
  { label: 'About', href: `${base}/about` },
  { label: 'Sevas', href: `${base}/sevas` },
  { label: 'Courses', href: `${base}/courses` },
  { label: 'Events', href: `${base}/events` },
  { label: 'Contact', href: `${base}/contact` },
];

const currentPath = Astro.url.pathname;
---

<!-- Top mantra bar -->
<div class="bg-maroon text-gold text-center py-1.5 text-xs md:text-sm tracking-widest font-heading overflow-hidden whitespace-nowrap" style="font-family: Georgia, 'Times New Roman', serif;">
  Hare Krishna Hare Krishna Krishna Krishna Hare Hare &bull; Hare Rama Hare Rama Rama Rama Hare Hare
</div>

<!-- Main header -->
<header class="bg-ivory border-b-2 border-gold/40 sticky top-0 z-50 shadow-md">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href={`${base}/`} class="flex items-center gap-3">
      <img src="https://iskconmumbaipull-21250.kxcdn.com/bi_theme_snippets/static/src/img/logo-black-header.png" alt="ISKCON" class="h-14 w-auto" />
      <div>
        <div class="text-2xl text-maroon leading-tight" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold; letter-spacing: 0.02em;">ISKCON Thoothukudi</div>
        <div class="text-xs text-warm-muted tracking-wide">International Society for Krishna Consciousness</div>
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'px-4 py-2 text-sm font-medium transition-colors',
            currentPath === item.href
              ? 'text-saffron-dark border-b-2 border-saffron-dark'
              : 'text-maroon hover:text-saffron-dark',
          ]}
          style="font-family: Georgia, 'Times New Roman', serif;"
        >
          {item.label}
        </a>
      ))}
      <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="ml-3 px-5 py-2 bg-saffron-dark text-white text-sm font-medium rounded hover:bg-saffron transition-colors" style="font-family: Georgia, 'Times New Roman', serif;">
        Donate
      </a>
    </nav>
    <button id="mobile-menu-btn" class="md:hidden p-2 text-maroon" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
  <nav id="mobile-menu" class="md:hidden hidden border-t border-gold/20 px-4 pb-3 bg-ivory">
    {navItems.map(item => (
      <a
        href={item.href}
        class:list={[
          'block py-2.5 text-sm border-b border-gold/10 last:border-0',
          currentPath === item.href ? 'text-saffron-dark font-medium' : 'text-maroon hover:text-saffron-dark',
        ]}
        style="font-family: Georgia, 'Times New Roman', serif;"
      >
        {item.label}
      </a>
    ))}
    <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="block mt-2 text-center px-4 py-2.5 bg-saffron-dark text-white text-sm font-medium rounded hover:bg-saffron transition-colors">
      Donate
    </a>
  </nav>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
