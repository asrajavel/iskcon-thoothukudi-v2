---

<footer class="bg-maroon text-cream mt-20 relative">
  <!-- Decorative top border pattern -->
  <div class="h-3 w-full" style="background: repeating-linear-gradient(90deg, transparent 0px, transparent 8px, #B8860B 8px, #B8860B 10px, transparent 10px, transparent 18px, #DAA520 18px, #DAA520 20px); border-top: 2px solid #B8860B; border-bottom: 2px solid #B8860B;"></div>
  <div class="h-1 w-full bg-gold/30"></div>

  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-4 gap-10">
      <div>
        <h3 class="text-lg mb-4 text-gold" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">ISKCON Thoothukudi</h3>
        <p class="text-sm text-cream/70 leading-relaxed">
          International Society for Krishna Consciousness<br />
          Thoothukudi, Tamil Nadu, India
        </p>
      </div>
      <div>
        <h3 class="text-lg mb-4 text-gold" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Temple Timings</h3>
        <div class="text-sm text-cream/70 space-y-1.5">
          <p>Morning: 4:30 AM - 1:00 PM</p>
          <p>Evening: 4:00 PM - 8:30 PM</p>
          <p>Sunday Feast: 5:00 PM</p>
        </div>
      </div>
      <div>
        <h3 class="text-lg mb-4 text-gold" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Contact</h3>
        <div class="text-sm text-cream/70 space-y-1.5">
          <p>Phone: +91 98765 43210</p>
          <p>Email: info@iskconthoothukudi.com</p>
        </div>
        <a href="https://pages.razorpay.com/ISKCON-KVA-DONATION" target="_blank" rel="noopener noreferrer" class="inline-block mt-4 px-5 py-2 border border-gold/50 text-gold text-sm font-medium rounded hover:bg-gold/10 transition-colors">
          Donate Now
        </a>
      </div>
      <div>
        <h3 class="text-lg mb-4 text-gold" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Maha Mantra</h3>
        <p class="text-sm text-gold-light italic leading-relaxed" style="font-family: Georgia, 'Times New Roman', serif;">
          Hare Krishna Hare Krishna<br />
          Krishna Krishna Hare Hare<br />
          Hare Rama Hare Rama<br />
          Rama Rama Hare Hare
        </p>
        <p class="text-xs text-cream/50 mt-3">
          Chant and be happy!
        </p>
      </div>
    </div>
    <div class="border-t border-gold/20 mt-10 pt-6 text-center text-sm text-cream/50">
      Hare Krishna Hare Krishna Krishna Krishna Hare Hare / Hare Rama Hare Rama Rama Rama Hare Hare
    </div>
  </div>
</footer>
