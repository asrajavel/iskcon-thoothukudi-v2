---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const courses = [
  {
    title: 'Bhagavad Gita Study',
    description: 'A systematic chapter-by-chapter study of the Bhagavad Gita As It Is by Srila Prabhupada. Understand the essence of Vedic philosophy and its practical application in daily life.',
    schedule: 'Every Saturday, 6:00 PM - 7:30 PM',
    duration: '18 weeks (one chapter per week)',
    level: 'Beginner',
    imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/d/d4/Radha_Krishna_ISKCON_Tirupati.JPG',
  },
  {
    title: 'Srimad Bhagavatam Classes',
    description: 'Daily morning discourse on the Srimad Bhagavatam, the ripened fruit of the Vedic literature. Covers the pastimes of Lord Krishna and His devotees.',
    schedule: 'Daily, 7:30 AM - 8:30 AM',
    duration: 'Ongoing',
    level: 'All levels',
    imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/2/2f/ISKCON_Juhu_Temple_Altars.JPG',
  },
];
---

<Layout title="Courses" description="Spiritual education programs at ISKCON Thoothukudi">
  <!-- Page Banner -->
  <section class="bg-maroon py-12 px-4 relative">
    <div class="absolute inset-0 opacity-20" style="background-image: repeating-linear-gradient(90deg, transparent 0px, transparent 18px, #B8860B 18px, #B8860B 20px); border-top: 3px solid #B8860B; border-bottom: 3px solid #B8860B;"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl text-gold mb-2" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Spiritual Education</h1>
      <p class="text-cream/80 max-w-xl mx-auto">
        Deepen your understanding of Vedic philosophy through our courses and programs.
        All programs are free and open to everyone.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="space-y-4">
      {courses.map((course, index) => (
        <details class="group bg-ivory border-l-4 border-l-gold shadow-md rounded-r-lg overflow-hidden">
          <summary class="cursor-pointer px-6 py-5 flex items-center justify-between hover:bg-warm-surface transition-colors list-none">
            <div class="flex items-center gap-3">
              <span class="text-gold text-xl">&#9753;</span>
              <div>
                <h3 class="text-lg text-warm-brown" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">{course.title}</h3>
                <span class="text-xs bg-saffron/10 text-saffron-dark px-2 py-0.5 rounded-full font-medium">{course.level}</span>
              </div>
            </div>
            <svg class="w-5 h-5 text-warm-muted group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-6 flex flex-col md:flex-row gap-6">
            <div class="flex-1">
              <p class="text-warm-muted text-sm leading-relaxed mb-4">{course.description}</p>
              <div class="flex flex-wrap gap-4 text-xs text-warm-muted">
                <div class="flex items-center gap-1 bg-warm-surface px-3 py-1.5 rounded">
                  <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  {course.schedule}
                </div>
                <div class="flex items-center gap-1 bg-warm-surface px-3 py-1.5 rounded">
                  <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  {course.duration}
                </div>
              </div>
            </div>
            <div class="md:w-52 shrink-0 overflow-hidden rounded">
              <img src={course.imageUrl} alt={course.title} class="w-full h-36 object-cover" loading="lazy" />
            </div>
          </div>
        </details>
      ))}
    </div>

    <hr class="my-10 border-gold/20" />

    <div class="text-center">
      <h2 class="text-2xl text-maroon mb-2" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Ready to begin your spiritual journey?</h2>
      <p class="text-warm-muted text-sm mb-4">All courses are free. Just walk in or contact us to register.</p>
      <a href={`${base}/contact`} class="inline-block bg-saffron-dark hover:bg-saffron text-white px-6 py-2.5 rounded text-sm font-medium transition-colors" style="font-family: Georgia, 'Times New Roman', serif;">
        Register Now
      </a>
    </div>
  </section>
</Layout>
