---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sevas = [
  { title: 'Abhishekam', description: 'Sacred bathing ceremony for the deities with milk, honey, ghee, curd, and holy water. Recommended for special occasions and festivals.', imageUrl: 'https://donations.iskconwhitefield.org/cdn/shop/files/Untitleddesign_13.png?v=1742070333', price: '₹1,116' },
  { title: 'Archana', description: 'Recitation of 108 names of the Lord. Available for Radha Krishna, Gaura Nitai, and Jagannath, Baladeva, Subhadra.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/d/d4/Radha_Krishna_ISKCON_Tirupati.JPG', price: '₹251' },

  { title: 'Annadan', description: 'Sponsor prasadam distribution to devotees and guests. Feed 50 people with a single donation.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/2/2a/Daily_Free_Prasadam_Distribution_at_ISKCON_Juhu.jpg', price: '₹2,500' },
  { title: 'Temple Construction', description: 'Contribute to the construction and development of the ISKCON Thoothukudi temple. Help build a magnificent house for the Lord.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/5/55/Radha_Krishna-chandra_Temple.jpg', price: '₹10,000' },

  { title: 'Deity Dress Sponsorship', description: 'Sponsor new clothes for the deities on special occasions. Includes your family name in the announcement.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/5/51/Sri_Caitanya_Mahaprabhu_and_Nityananda_Mahaprabhu%21.jpg', price: '₹5,001' },
];
---

<Layout title="Sevas" description="Participate in temple sevas and worship services at ISKCON Thoothukudi">
  <!-- Page Banner -->
  <section class="bg-maroon py-12 px-4 relative">
    <div class="absolute inset-0 opacity-20" style="background-image: repeating-linear-gradient(90deg, transparent 0px, transparent 18px, #B8860B 18px, #B8860B 20px); border-top: 3px solid #B8860B; border-bottom: 3px solid #B8860B;"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl text-gold mb-2" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Temple Sevas</h1>
      <p class="text-cream/80 max-w-xl mx-auto">
        Participate in devotional services and receive the blessings of Sri Sri Radha Krishna.
        All sevas include prasadam for your family.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-2 gap-8">
      {sevas.map(seva => (
        <div class="overflow-hidden bg-ivory border-l-4 border-l-gold shadow-md shadow-warm-brown/10 rounded-r-lg hover:shadow-lg transition-shadow">
          <div class="h-44 overflow-hidden">
            <img src={seva.imageUrl} alt={seva.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-5 relative">
            <!-- Price badge -->
            <div class="absolute -top-7 right-5 w-14 h-14 rounded-full bg-gold flex items-center justify-center shadow-lg">
              <span class="text-white text-xs font-bold text-center leading-tight">{seva.price}</span>
            </div>
            <h3 class="text-warm-brown text-lg mb-2" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">{seva.title}</h3>
            <p class="text-warm-muted text-sm leading-relaxed mb-4">{seva.description}</p>
            <a href="https://pages.razorpay.com/ISKCON-KVA-DONATION" target="_blank" rel="noopener noreferrer" class="w-full block text-center border-2 border-saffron-dark text-saffron-dark hover:bg-saffron-dark hover:text-white py-2 rounded text-sm font-medium transition-colors" style="font-family: Georgia, 'Times New Roman', serif;">
              Book This Seva
            </a>
          </div>
        </div>
      ))}
    </div>

    <hr class="my-10 border-gold/20" />

    <div class="text-center">
      <h2 class="text-2xl text-maroon mb-2" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Want to book a seva?</h2>
      <p class="text-warm-muted text-sm mb-4">
        Contact us directly to book any seva. We accept UPI, bank transfer, and cash.
      </p>
      <a href={`${base}/contact`} class="inline-block bg-saffron-dark hover:bg-saffron text-white px-6 py-2.5 rounded text-sm font-medium transition-colors" style="font-family: Georgia, 'Times New Roman', serif;">
        Contact Temple Office
      </a>
    </div>
  </section>
</Layout>
