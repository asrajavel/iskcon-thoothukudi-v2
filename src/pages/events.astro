---
import Layout from '../layouts/Layout.astro';

const events = [
  {
    title: 'Janmashtami 2026',
    date: 'August 14, 2026',
    time: '4:00 PM - 12:30 AM',
    description: 'Grand celebration of Lord Krishna\'s appearance day. Join us for an evening of kirtan, drama performances depicting Krishna\'s pastimes, abhishekam at midnight, and sumptuous prasadam feast.',
    highlight: true,
  },
  {
    title: 'Sunday Love Feast',
    date: 'Every Sunday',
    time: '5:00 PM - 8:00 PM',
    description: 'Weekly program featuring ecstatic kirtan, enlightening discourse on Bhagavad Gita, and a delicious multi-course prasadam feast. Everyone is welcome!',
    highlight: false,
  },
  {
    title: 'Gaura Purnima',
    date: 'March 2027',
    time: 'All Day',
    description: 'Celebration of the appearance of Lord Chaitanya Mahaprabhu, the most merciful incarnation who spread the Hare Krishna movement 500 years ago.',
    highlight: false,
  },
  {
    title: 'Ratha Yatra',
    date: 'July 2026',
    time: '8:00 AM - 6:00 PM',
    description: 'The grand chariot festival of Lord Jagannath through the streets of Thoothukudi. Massive procession with kirtan, dance, and free prasadam distribution.',
    highlight: true,
  },
  {
    title: 'Govardhan Puja',
    date: 'October 2026',
    time: '9:00 AM - 1:00 PM',
    description: 'Celebration of Lord Krishna lifting Govardhan Hill. Features a grand Annakut (hill of food) offering with 108+ preparations.',
    highlight: false,
  },
  {
    title: 'Kirtan Mela',
    date: 'Monthly (Last Saturday)',
    time: '6:00 PM - 9:00 PM',
    description: 'An evening of continuous kirtan with visiting kirtaniyas from ISKCON centers across South India. Deep, meditative chanting experience.',
    highlight: false,
  },
];
---

<Layout title="Events" description="Upcoming festivals and events at ISKCON Thoothukudi">
  <!-- Page Banner -->
  <section class="bg-maroon py-12 px-4 relative">
    <div class="absolute inset-0 opacity-20" style="background-image: repeating-linear-gradient(90deg, transparent 0px, transparent 18px, #B8860B 18px, #B8860B 20px); border-top: 3px solid #B8860B; border-bottom: 3px solid #B8860B;"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl text-gold mb-3" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">Events & Festivals</h1>
      <p class="text-cream/80 max-w-xl mx-auto">
        Join us in celebrating the timeless Vedic festivals and special programs
        throughout the year. All events are free and open to everyone.
      </p>
    </div>
  </section>

  <!-- Timeline -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="relative">
      <!-- Vertical timeline line -->
      <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-0.5 bg-gold/40 transform md:-translate-x-px"></div>

      <div class="space-y-10">
        {events.map((event, i) => (
          <div class={`relative flex flex-col md:flex-row ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-start gap-8`}>
            <!-- Timeline dot -->
            <div class="absolute left-6 md:left-1/2 w-3 h-3 rounded-full bg-gold border-2 border-ivory transform -translate-x-1/2 mt-6 z-10"></div>

            <!-- Spacer for alternating -->
            <div class="hidden md:block md:w-1/2"></div>

            <!-- Event card -->
            <div class={`ml-14 md:ml-0 md:w-1/2 ${i % 2 === 0 ? 'md:pr-10' : 'md:pl-10'}`}>
              <div class={`bg-ivory border-l-4 ${event.highlight ? 'border-l-saffron-dark' : 'border-l-gold'} shadow-md rounded-r-lg p-5 hover:shadow-lg transition-shadow relative`}>
                {event.highlight && (
                  <div class="absolute -top-2 -right-2 w-8 h-8 bg-saffron-dark rounded-full flex items-center justify-center shadow-md">
                    <span class="text-white text-sm">&#9733;</span>
                  </div>
                )}
                <div class="text-xs text-saffron-dark font-medium mb-1">{event.date} &bull; {event.time}</div>
                <h3 class="text-lg text-warm-brown mb-2" style="font-family: Georgia, 'Times New Roman', serif; font-weight: bold;">{event.title}</h3>
                <p class="text-warm-muted text-sm leading-relaxed">{event.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
